{
  "name": "nostr-double-ratchet",
  "version": "0.0.165",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "description": "Nostr double ratchet library",
  "main": "dist/nostr-double-ratchet.es.js",
  "module": "dist/nostr-double-ratchet.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/nostr-double-ratchet.es.js",
      "default": "./dist/nostr-double-ratchet.es.js"
    }
  },
  "scripts": {
    "test": "vitest --exclude '**/*.integration.test.ts'",
    "test:once": "vitest run --exclude '**/*.integration.test.ts'",
    "test:integration": "DEBUG='ndk:*' vitest run tests/*.integration.test.ts",
    "bench:relay-churn": "tsx bench/relayChurn.ts",
    "build": "vite build && tsc",
    "prepare": "pnpm run build",
    "lint": "eslint src --ext .ts --fix"
  },
  "repository": {
    "type": "git",
    "url": "https://files.iris.to/#/npub1xdhnr9mrv47kkrn95k6cwecearydeh8e895990n3acntwvmgk2dsdeeycm/nostr-double-ratchet"
  },
  "author": "Martti Malmi",
  "license": "MIT",
  "homepage": "https://files.iris.to/#/npub1xdhnr9mrv47kkrn95k6cwecearydeh8e895990n3acntwvmgk2dsdeeycm/nostr-double-ratchet",
  "files": [
    "src",
    "dist"
  ],
  "devDependencies": {
    "@noble/hashes": "^1.3.1",
    "@nostr-dev-kit/ndk": "2.14.23",
    "@types/node": "^22.20.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "tsx": "^4.23.1",
    "typescript": "^5.8.3",
    "vite": "^6.4.3",
    "vitest": "^3.2.7",
    "ws": "^8.21.1"
  },
  "dependencies": {
    "nostr-tools": "^2.23.12"
  },
  "pnpm": {
    "overrides": {
      "yaml": "2.8.3"
    }
  }
}
